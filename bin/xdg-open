#!/bin/sh

case "$1" in
    http:*|https:*)
        if command -v flatpak >/dev/null 2>&1 && flatpak info org.mozilla.firefox >/dev/null 2>&1; then
            exec flatpak run org.mozilla.firefox "$1"
        else
            exec /usr/bin/xdg-open "$@"
        fi
        ;;
    *.pdf)
        exec zathura "$1"
        ;;
    *.jpg|*.jpeg|*.png|*.gif|*.bmp|*.webp)
        exec feh "$1"
        ;;
    *)
        exec /usr/bin/xdg-open "$@"
        ;;
esac

